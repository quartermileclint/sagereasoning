# SageReasoning Environment Variables
# Copy this file to .env.local and fill in your real values
# NEVER commit .env.local to GitHub — it contains secrets

# Supabase (get these from your Supabase project dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Anthropic API (optional — only needed if using Claude for live scoring)
# Get from console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Site URL (used for auth redirects)
NEXT_PUBLIC_SITE_URL=https://sagereasoning.com

# Stripe (get these from dashboard.stripe.com → Developers → API keys)
# See /docs/Stripe_Setup_Guide.md for step-by-step instructions
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key-here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret-here

# Stripe Product/Price IDs (create these in the Stripe Dashboard — see setup guide)
# Developer paid tier — per-call API access
STRIPE_DEVELOPER_PRICE_ID=price_your-developer-plan-price-id
# Voluntary tidings — one-off donation product
STRIPE_TIDING_ONCEOFF_PRICE_ID=price_your-oneoff-tiding-price-id
# Voluntary tidings — monthly recurring donation product
STRIPE_TIDING_MONTHLY_PRICE_ID=price_your-monthly-tiding-price-id
