{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://sagereasoning.com/stoic-brain/schema.json",
  "title": "SageReasoning Stoic Brain Schema",
  "description": "Defines the structure of the public stoic-brain data files. Scoring weight properties are omitted from this public schema — they are applied server-side through the SageReasoning API.",
  "version": "1.1.0",
  "definitions": {
    "virtue": {
      "type": "object",
      "required": ["id", "name", "greek", "description", "sub_virtues"],
      "properties": {
        "id": { "type": "string", "description": "Unique slug, e.g. 'wisdom'" },
        "name": { "type": "string" },
        "greek": { "type": "string", "description": "Original Greek term, e.g. 'phronesis'" },
        "description": { "type": "string" },
        "opposite_vice": { "type": "string", "description": "The opposing vice/deficiency" },
        "sub_virtues": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "name"],
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" }
            }
          }
        },
        "source_citations": {
          "type": "array",
          "items": { "type": "string" },
          "description": "References to primary stoic texts"
        }
      }
    },
    "indifferent": {
      "type": "object",
      "required": ["id", "name", "category", "description"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": {
          "type": "string",
          "enum": ["preferred", "dispreferred", "neutral"],
          "description": "Stoic classification of this external thing"
        },
        "description": { "type": "string" }
      }
    },
    "action_score": {
      "type": "object",
      "description": "Returned by the SageReasoning API scoring endpoints",
      "required": ["action_description", "virtue_scores", "total_score", "reasoning"],
      "properties": {
        "action_description": { "type": "string" },
        "virtue_scores": {
          "type": "object",
          "properties": {
            "wisdom": { "type": "number", "minimum": 0, "maximum": 100 },
            "justice": { "type": "number", "minimum": 0, "maximum": 100 },
            "courage": { "type": "number", "minimum": 0, "maximum": 100 },
            "temperance": { "type": "number", "minimum": 0, "maximum": 100 }
          }
        },
        "total_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Weighted composite stoic score (0 = fully vicious, 100 = perfect sage)"
        },
        "sage_alignment": {
          "type": "string",
          "enum": ["sage", "progressing", "aware", "misaligned", "contrary"],
          "description": "Qualitative tier classification"
        },
        "reasoning": { "type": "string" },
        "improvement_path": { "type": "string", "description": "What a sage would do differently" }
      }
    }
  }
}
