<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SageReasoning Ecosystem Map v2</title>
<style>
  :root {
    --bg: #0a0e17;
    --surface: #131a2b;
    --surface2: #1a2340;
    --surface3: #1e2a4a;
    --border: #2a3555;
    --border-light: #3a4570;
    --text: #e0e6f0;
    --text-dim: #8892a8;
    --text-muted: #5a6480;
    --gold: #d4a843;
    --gold-dim: #a07a20;
    --gold-bg: rgba(212,168,67,0.08);

    /* Category colours */
    --product: #60a5fa;
    --tool: #f472b6;
    --agent: #f59e0b;
    --engine: #ef4444;
    --reasoning: #a78bfa;
    --data: #34d399;
    --infra: #22d3ee;
    --governance: #ec4899;
    --document: #94a3b8;

    /* Status colours */
    --live: #22c55e;
    --verified: #3b82f6;
    --wired: #a855f7;
    --scaffolded: #f59e0b;
    --designed: #f97316;
    --scoped: #ef4444;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    line-height: 1.5;
  }

  /* ===== HEADER ===== */
  .header {
    background: linear-gradient(135deg, var(--surface) 0%, var(--surface2) 100%);
    border-bottom: 1px solid var(--border);
    padding: 16px 28px;
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .header-top { display: flex; align-items: baseline; gap: 12px; margin-bottom: 2px; }
  .header h1 { font-size: 20px; font-weight: 700; color: var(--gold); }
  .header .version { font-size: 11px; color: var(--text-dim); }
  .header p { font-size: 12px; color: var(--text-dim); margin-bottom: 10px; }

  .controls { display: flex; gap: 6px; flex-wrap: wrap; align-items: center; }
  .control-group { display: flex; gap: 3px; align-items: center; flex-wrap: wrap; }
  .control-group label {
    font-size: 10px; color: var(--text-muted); text-transform: uppercase;
    letter-spacing: 0.6px; margin-right: 3px; white-space: nowrap;
  }

  .filter-btn {
    padding: 3px 8px; border-radius: 3px; border: 1px solid var(--border);
    background: var(--surface); color: var(--text-dim); font-size: 10px;
    cursor: pointer; transition: all 0.12s; white-space: nowrap;
  }
  .filter-btn:hover { border-color: var(--gold-dim); color: var(--text); }
  .filter-btn.active { background: var(--gold-dim); color: #fff; border-color: var(--gold); }

  .search-box {
    padding: 4px 8px; border-radius: 3px; border: 1px solid var(--border);
    background: var(--surface); color: var(--text); font-size: 11px;
    width: 180px; outline: none;
  }
  .search-box:focus { border-color: var(--gold); }

  .divider { width: 1px; height: 20px; background: var(--border); margin: 0 6px; }

  /* ===== STATS BAR ===== */
  .stats-bar {
    display: flex; gap: 12px; padding: 8px 28px;
    background: var(--surface); border-bottom: 1px solid var(--border);
    font-size: 11px; flex-wrap: wrap; align-items: center;
  }
  .stat { display: flex; align-items: center; gap: 4px; }
  .stat-dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }
  .stat-count { color: var(--gold); font-weight: 600; }

  /* ===== LAYOUT ===== */
  .main { display: grid; grid-template-columns: 260px 1fr; min-height: calc(100vh - 130px); }

  .sidebar {
    background: var(--surface); border-right: 1px solid var(--border);
    padding: 14px; overflow-y: auto; max-height: calc(100vh - 130px);
    position: sticky; top: 130px; font-size: 11px;
  }
  .sidebar h3 {
    font-size: 10px; text-transform: uppercase; letter-spacing: 0.8px;
    color: var(--text-muted); margin: 14px 0 6px; padding-bottom: 4px;
    border-bottom: 1px solid var(--border);
  }
  .sidebar h3:first-child { margin-top: 0; }

  .legend-item { display: flex; align-items: center; gap: 6px; padding: 2px 0; font-size: 11px; }
  .legend-swatch { width: 12px; height: 12px; border-radius: 2px; flex-shrink: 0; }
  .status-pip { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }

  .subtype-list { padding-left: 20px; color: var(--text-dim); font-size: 10px; line-height: 1.6; }

  .content { padding: 16px 20px; overflow-y: auto; max-height: calc(100vh - 130px); }

  /* ===== SECTIONS ===== */
  .section { margin-bottom: 24px; }
  .section-header {
    display: flex; align-items: center; gap: 8px; margin-bottom: 10px;
    padding-bottom: 6px; border-bottom: 1px solid var(--border);
    cursor: pointer; user-select: none;
  }
  .section-header:hover { border-bottom-color: var(--gold-dim); }
  .section-icon {
    width: 22px; height: 22px; border-radius: 4px;
    display: flex; align-items: center; justify-content: center;
    font-size: 10px; font-weight: 800; color: #fff;
  }
  .section-title { font-size: 14px; font-weight: 600; }
  .section-subtitle { font-size: 11px; color: var(--text-dim); }
  .section-count { font-size: 10px; color: var(--text-dim); margin-left: auto; }
  .section-toggle { font-size: 12px; color: var(--text-dim); transition: transform 0.2s; }
  .section.collapsed .section-toggle { transform: rotate(-90deg); }
  .section.collapsed .cards-grid { display: none; }

  /* ===== CARDS ===== */
  .cards-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 8px; }

  .card {
    background: var(--surface); border: 1px solid var(--border); border-radius: 5px;
    padding: 10px 12px; transition: all 0.12s; cursor: pointer;
    position: relative; overflow: hidden;
  }
  .card::before {
    content: ''; position: absolute; top: 0; left: 0; width: 3px; height: 100%;
  }
  .card[data-type="product"]::before { background: var(--product); }
  .card[data-type="tool"]::before { background: var(--tool); }
  .card[data-type="agent"]::before { background: var(--agent); }
  .card[data-type="engine"]::before { background: var(--engine); }
  .card[data-type="reasoning"]::before { background: var(--reasoning); }
  .card[data-type="data"]::before { background: var(--data); }
  .card[data-type="infra"]::before { background: var(--infra); }
  .card[data-type="governance"]::before { background: var(--governance); }
  .card[data-type="document"]::before { background: var(--document); }

  .card:hover { border-color: var(--gold-dim); background: var(--surface2); }
  .card.expanded { border-color: var(--gold); grid-column: 1 / -1; background: var(--surface2); }

  .card-top { display: flex; align-items: flex-start; gap: 6px; margin-bottom: 4px; }
  .card-name { font-size: 12px; font-weight: 600; flex: 1; word-break: break-word; }

  .card-badges { display: flex; gap: 3px; flex-shrink: 0; flex-wrap: wrap; justify-content: flex-end; }

  .badge {
    padding: 1px 5px; border-radius: 2px; font-size: 8px; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.3px; white-space: nowrap;
  }
  .badge-status-live { background: var(--live); color: #fff; }
  .badge-status-verified { background: var(--verified); color: #fff; }
  .badge-status-wired { background: var(--wired); color: #fff; }
  .badge-status-scaffolded { background: var(--scaffolded); color: #000; }
  .badge-status-designed { background: var(--designed); color: #fff; }
  .badge-status-scoped { background: var(--scoped); color: #fff; }

  .badge-ext { background: var(--surface2); border: 1px solid var(--border); color: var(--text-dim); }

  .badge-subtype {
    background: transparent; border: 1px solid currentColor; font-size: 8px;
    padding: 0px 4px; border-radius: 2px;
  }
  .badge-subtype[data-st="deterministic"] { color: #60a5fa; }
  .badge-subtype[data-st="llm-powered"] { color: #f472b6; }
  .badge-subtype[data-st="retrieval"] { color: #34d399; }
  .badge-subtype[data-st="evaluation"] { color: #fbbf24; }
  .badge-subtype[data-st="transformation"] { color: #a78bfa; }
  .badge-subtype[data-st="action"] { color: #f87171; }
  .badge-subtype[data-st="reactive"] { color: #60a5fa; }
  .badge-subtype[data-st="planning"] { color: #fbbf24; }
  .badge-subtype[data-st="autonomous"] { color: #f87171; }
  .badge-subtype[data-st="multi-agent"] { color: #a78bfa; }
  .badge-subtype[data-st="economic"] { color: #34d399; }
  .badge-subtype[data-st="inference"] { color: #f87171; }
  .badge-subtype[data-st="workflow"] { color: #fbbf24; }
  .badge-subtype[data-st="memory"] { color: #a78bfa; }
  .badge-subtype[data-st="execution"] { color: #60a5fa; }
  .badge-subtype[data-st="search"] { color: #34d399; }
  .badge-subtype[data-st="simulation"] { color: #22d3ee; }
  .badge-subtype[data-st="logical"] { color: #60a5fa; }
  .badge-subtype[data-st="causal"] { color: #f87171; }
  .badge-subtype[data-st="heuristic"] { color: #fbbf24; }
  .badge-subtype[data-st="reflective"] { color: #a78bfa; }
  .badge-subtype[data-st="multi-step"] { color: #34d399; }
  .badge-subtype[data-st="probabilistic"] { color: #22d3ee; }
  .badge-subtype[data-st="analogical"] { color: #f472b6; }
  .badge-subtype[data-st="tool-augmented"] { color: #94a3b8; }

  .badge-rule { background: transparent; border: 1px solid var(--governance); color: var(--governance); font-size: 7px; }

  .badge-prox-sage-like { background: linear-gradient(135deg, #d4a843, #b8922e); color: #000; font-weight: 800; letter-spacing: 0.5px; }
  .badge-prox-principled { background: #3b82f6; color: #fff; font-weight: 700; }
  .badge-prox-deliberate { background: #a855f7; color: #fff; font-weight: 700; }
  .badge-prox-habitual { background: #f59e0b; color: #000; font-weight: 700; }
  .badge-prox-reflexive { background: #ef4444; color: #fff; font-weight: 700; }

  .card-desc { font-size: 10px; color: var(--text-dim); margin-bottom: 4px; line-height: 1.4; }
  .card-path { font-size: 9px; color: var(--text-muted); font-family: 'SF Mono','Fira Code',monospace; word-break: break-all; }

  .card-details { display: none; margin-top: 8px; padding-top: 8px; border-top: 1px solid var(--border); }
  .card.expanded .card-details { display: block; }

  .detail-row { display: flex; gap: 6px; margin-bottom: 4px; font-size: 10px; }
  .detail-label { color: var(--text-muted); min-width: 70px; flex-shrink: 0; }
  .detail-value { color: var(--text); }

  .dep-tag {
    display: inline-block; padding: 0px 4px; border-radius: 2px; font-size: 9px;
    margin: 1px; background: var(--surface2); border: 1px solid var(--border); color: var(--text-dim);
  }
  .dep-tag.external { border-color: var(--infra); color: var(--infra); }
  .priority-tag {
    display: inline-block; padding: 0px 4px; border-radius: 2px; font-size: 9px;
    background: transparent; border: 1px solid var(--gold-dim); color: var(--gold);
  }

  @media (max-width: 900px) {
    .main { grid-template-columns: 1fr; }
    .sidebar { display: none; }
    .cards-grid { grid-template-columns: 1fr; }
  }
</style>
</head>
<body>

<div class="header">
  <div class="header-top">
    <h1>SageReasoning Ecosystem Map</h1>
    <span class="version">v2 — Agent-Native Taxonomy</span>
  </div>
  <p>P0 Foundation. 9 categories with typed subtypes. Every component, connection, and status. 6 April 2026.</p>
  <div class="controls">
    <div class="control-group">
      <label>Category:</label>
      <button class="filter-btn active" data-filter-type="all">All</button>
      <button class="filter-btn" data-filter-type="product">Products</button>
      <button class="filter-btn" data-filter-type="tool">Tools</button>
      <button class="filter-btn" data-filter-type="agent">Agents</button>
      <button class="filter-btn" data-filter-type="engine">Engines</button>
      <button class="filter-btn" data-filter-type="reasoning">Reasoning</button>
      <button class="filter-btn" data-filter-type="data">Data</button>
      <button class="filter-btn" data-filter-type="infra">Infra</button>
      <button class="filter-btn" data-filter-type="governance">Governance</button>
      <button class="filter-btn" data-filter-type="document">Documents</button>
    </div>
    <div class="divider"></div>
    <div class="control-group">
      <label>Status:</label>
      <button class="filter-btn active" data-filter-status="all">All</button>
      <button class="filter-btn" data-filter-status="live">Live</button>
      <button class="filter-btn" data-filter-status="verified">Verified</button>
      <button class="filter-btn" data-filter-status="wired">Wired</button>
      <button class="filter-btn" data-filter-status="scaffolded">Scaffolded</button>
      <button class="filter-btn" data-filter-status="designed">Designed</button>
      <button class="filter-btn" data-filter-status="scoped">Scoped</button>
    </div>
    <div class="divider"></div>
    <div class="control-group">
      <label>PROXIMITY</label>
      <button class="filter-btn active" data-filter-prox="all">All</button>
      <button class="filter-btn" data-filter-prox="sage-like">Sage-like</button>
      <button class="filter-btn" data-filter-prox="principled">Principled</button>
      <button class="filter-btn" data-filter-prox="deliberate">Deliberate</button>
      <button class="filter-btn" data-filter-prox="habitual">Habitual</button>
      <button class="filter-btn" data-filter-prox="reflexive">Reflexive</button>
      <button class="filter-btn" data-filter-prox="none">Non-reasoning</button>
    </div>
    <div class="divider"></div>
    <input type="text" class="search-box" placeholder="Search..." id="searchBox">
  </div>
</div>

<div class="stats-bar" id="statsBar"></div>

<div class="main">
  <div class="sidebar">
    <h3>Categories</h3>
    <div class="legend-item"><div class="legend-swatch" style="background:var(--product)"></div><strong>Products</strong> — Human-facing interfaces</div>
    <div class="legend-item"><div class="legend-swatch" style="background:var(--tool)"></div><strong>Tools</strong> — Agent functions (I/O)</div>
    <div class="legend-item"><div class="legend-swatch" style="background:var(--agent)"></div><strong>Agents</strong> — Decision makers over tools</div>
    <div class="legend-item"><div class="legend-swatch" style="background:var(--engine)"></div><strong>Engines</strong> — Runtime systems</div>
    <div class="legend-item"><div class="legend-swatch" style="background:var(--reasoning)"></div><strong>Reasoning</strong> — Internal strategic thinking</div>
    <div class="legend-item"><div class="legend-swatch" style="background:var(--data)"></div><strong>Data</strong> — Storage / schemas</div>
    <div class="legend-item"><div class="legend-swatch" style="background:var(--infra)"></div><strong>Infra</strong> — API / auth / hosting</div>
    <div class="legend-item"><div class="legend-swatch" style="background:var(--governance)"></div><strong>Governance</strong> — Rules / compliance</div>
    <div class="legend-item"><div class="legend-swatch" style="background:var(--document)"></div><strong>Documents</strong> — Strategy / research</div>

    <h3>Tool Subtypes</h3>
    <div class="subtype-list">
      <span class="badge-subtype" data-st="deterministic">deterministic</span> Rule-based, no LLM<br>
      <span class="badge-subtype" data-st="llm-powered">llm-powered</span> Claude inference<br>
      <span class="badge-subtype" data-st="retrieval">retrieval</span> Fetches stored data<br>
      <span class="badge-subtype" data-st="action">action</span> Executes side-effects<br>
      <span class="badge-subtype" data-st="transformation">transformation</span> Reshapes data<br>
      <span class="badge-subtype" data-st="evaluation">evaluation</span> Scores/judges input
    </div>

    <h3>Agent Subtypes</h3>
    <div class="subtype-list">
      <span class="badge-subtype" data-st="reactive">reactive</span> Stimulus-response<br>
      <span class="badge-subtype" data-st="planning">planning</span> Goal decomposition<br>
      <span class="badge-subtype" data-st="autonomous">autonomous</span> Self-directed<br>
      <span class="badge-subtype" data-st="multi-agent">multi-agent</span> Orchestrates others<br>
      <span class="badge-subtype" data-st="economic">economic</span> Resource-optimising
    </div>

    <h3>Engine Subtypes</h3>
    <div class="subtype-list">
      <span class="badge-subtype" data-st="inference">inference</span> Produces conclusions<br>
      <span class="badge-subtype" data-st="workflow">workflow</span> Orchestrates steps<br>
      <span class="badge-subtype" data-st="memory">memory</span> Persists/recalls state<br>
      <span class="badge-subtype" data-st="execution">execution</span> Runs tasks<br>
      <span class="badge-subtype" data-st="search">search</span> Finds relevant data<br>
      <span class="badge-subtype" data-st="simulation">simulation</span> Models scenarios
    </div>

    <h3>Reasoning Subtypes</h3>
    <div class="subtype-list">
      <span class="badge-subtype" data-st="logical">logical</span> Deductive/binary<br>
      <span class="badge-subtype" data-st="causal">causal</span> Why did this happen<br>
      <span class="badge-subtype" data-st="heuristic">heuristic</span> Rule-of-thumb<br>
      <span class="badge-subtype" data-st="reflective">reflective</span> Self-examining<br>
      <span class="badge-subtype" data-st="multi-step">multi-step</span> Sequential chains<br>
      <span class="badge-subtype" data-st="probabilistic">probabilistic</span> Uncertainty-aware<br>
      <span class="badge-subtype" data-st="analogical">analogical</span> Pattern mapping<br>
      <span class="badge-subtype" data-st="tool-augmented">tool-augmented</span> Uses tools to reason
    </div>

    <h3>Status Levels</h3>
    <div class="legend-item"><div class="status-pip" style="background:var(--live)"></div> Live — Deployed</div>
    <div class="legend-item"><div class="status-pip" style="background:var(--verified)"></div> Verified — Tested</div>
    <div class="legend-item"><div class="status-pip" style="background:var(--wired)"></div> Wired — Connected</div>
    <div class="legend-item"><div class="status-pip" style="background:var(--scaffolded)"></div> Scaffolded — Code exists</div>
    <div class="legend-item"><div class="status-pip" style="background:var(--designed)"></div> Designed — Architecture decided</div>
    <div class="legend-item"><div class="status-pip" style="background:var(--scoped)"></div> Scoped — Requirements only</div>

    <h3>Katorthoma Proximity</h3>
    <div class="legend-item"><div class="badge badge-prox-sage-like">SAGE</div> Sage-like — Fully aligned reasoning</div>
    <div class="legend-item"><div class="badge badge-prox-principled">PRIN</div> Principled — Consistent principle application</div>
    <div class="legend-item"><div class="badge badge-prox-deliberate">DLIB</div> Deliberate — Conscious examination</div>
    <div class="legend-item"><div class="badge badge-prox-habitual">HBIT</div> Habitual — Pattern-based awareness</div>
    <div class="legend-item"><div class="badge badge-prox-reflexive">RFLX</div> Reflexive — Reactive, unexamined</div>
    <div class="legend-item"><div class="badge" style="background: #4b5563; color: #bbb;">—</div> Non-reasoning capability</div>

    <h3>Counts</h3>
    <div id="sidebarStats"></div>
  </div>

  <div class="content" id="content"></div>
</div>

<script>
const EXTERNALS = ['supabase','claude-api','stripe','vercel','resend','embedding-api','react-simple-maps'];

const C = [
  // =============================================
  // PRODUCTS — Human-facing interfaces/experiences
  // =============================================
  {id:"prod-action-scorer",name:"Action Scorer",type:"product",subtype:[],status:"scaffolded",ext:".tsx",path:"/website/src/app/score/page.tsx",desc:"Human interface for scoring an action. Captures action text, context, relationships, emotional state. Calls sage-score tool.",deps:["supabase","claude-api"],rules:["R3","R6","R9"],priority:"P6",proximity:"",connects:["tool-sage-score","engine-4stage"]},
  {id:"prod-journal",name:"55-Day Stoic Journal",type:"product",subtype:[],status:"scaffolded",ext:".tsx",path:"/website/src/app/journal/page.tsx",desc:"8-phase journal with daily teachings, source citations, cloud/local storage, client-side AES-256-GCM encryption.",deps:["supabase"],rules:["R7","R17"],priority:"P6",proximity:"",connects:["engine-journal-content","data-journal-entries","infra-encryption"]},
  {id:"prod-baseline",name:"Baseline Assessment",type:"product",subtype:[],status:"scaffolded",ext:".tsx",path:"/website/src/app/baseline/page.tsx",desc:"5-6 question Stoic baseline assessment with branching Q6. Produces Senecan grade + 4 dimension levels.",deps:["supabase","claude-api"],rules:["R6c","R3"],priority:"P6",proximity:"",connects:["engine-baseline","data-baseline-table"]},
  {id:"prod-dashboard",name:"User Dashboard",type:"product",subtype:[],status:"scaffolded",ext:".tsx",path:"/website/src/app/dashboard/page.tsx",desc:"Progress profile: baseline results, evaluation history, practice calendar with virtue stamps, milestones.",deps:["supabase"],rules:["R3"],priority:"P6",proximity:"",connects:["data-evaluations"]},
  {id:"prod-doc-scorer",name:"Document Scorer",type:"product",subtype:[],status:"scaffolded",ext:".tsx",path:"/website/src/app/score-document/page.tsx",desc:"Human interface for scoring documents/policies against Stoic principles.",deps:["claude-api","supabase"],rules:["R3","R9"],priority:"P6",proximity:"",connects:["tool-sage-audit"]},
  {id:"prod-social-filter",name:"Social Media Filter",type:"product",subtype:[],status:"scaffolded",ext:".tsx",path:"/website/src/app/score-social/page.tsx",desc:"Human interface for filtering social content through Stoic reasoning.",deps:["claude-api"],rules:["R3","R9"],priority:"P6",proximity:"",connects:["tool-sage-filter"]},
