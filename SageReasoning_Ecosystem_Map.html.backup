// ===== SECTIONS CONFIG =====
const SECTIONS = [
  {key:'product',label:'Products',sub:'Human-Facing Interfaces',color:'var(--product)',icon:'P'},
  {key:'tool',label:'Tools',sub:'Core Agent Functions (Inputs/Outputs)',color:'var(--tool)',icon:'Fn'},
  {key:'agent',label:'Agents',sub:'Decision Makers Over Tools',color:'var(--agent)',icon:'Ag'},
  {key:'engine',label:'Engines',sub:'Runtime Systems',color:'var(--engine)',icon:'En'},
  {key:'reasoning',label:'Reasoning',sub:'Internal Strategic Thinking',color:'var(--reasoning)',icon:'Re'},
  {key:'data',label:'Data',sub:'Storage, Schemas, State',color:'var(--data)',icon:'Db'},
  {key:'infra',label:'Infrastructure',sub:'API, Auth, Hosting, Integration',color:'var(--infra)',icon:'If'},
  {key:'governance',label:'Governance',sub:'Rules, Compliance, Workflows',color:'var(--governance)',icon:'Gv'},
  {key:'document',label:'Documents',sub:'Strategy, Research, Business',color:'var(--document)',icon:'Dc'},
];

let activeTypeFilter = 'all';
let activeStatusFilter = 'all';
let activeProxFilter = 'all';
let searchTerm = '';
let expandedCard = null;

function getFiltered() {
  return C.filter(c => {
    if (activeTypeFilter !== 'all' && c.type !== activeTypeFilter) return false;
    if (activeStatusFilter !== 'all' && c.status !== activeStatusFilter) return false;
    if (activeProxFilter !== 'all') {
      if (activeProxFilter === 'none') {
        if (c.proximity) return false;
      } else {
        if (c.proximity !== activeProxFilter) return false;
      }
    }
    if (searchTerm) {
      const s = searchTerm.toLowerCase();
      return c.name.toLowerCase().includes(s) || c.desc.toLowerCase().includes(s) ||
        c.path.toLowerCase().includes(s) || (c.rules||[]).some(r=>r.toLowerCase().includes(s)) ||
        c.type.includes(s) || (c.subtype||[]).some(st=>st.includes(s)) || (c.proximity||'').includes(s);
    }
    return true;
  });
}

function renderStats() {
  const f = getFiltered();
  const statuses = {};
  const proximities = {};
  f.forEach(c => {
    statuses[c.status] = (statuses[c.status]||0)+1;
    proximities[c.proximity || 'none'] = (proximities[c.proximity || 'none']||0)+1;
  });

  document.getElementById('statsBar').innerHTML =
    `<div class="stat"><span class="stat-count">${f.length}</span> of ${C.length} shown</div>` +
    Object.entries(statuses).map(([s,n]) =>
      `<div class="stat"><div class="stat-dot" style="background:var(--${s})"></div>${s} <span class="stat-count">${n}</span></div>`
    ).join('') +
    `<div class="divider"></div>` +
    Object.entries(proximities).map(([p,n]) => {
      let color = p === 'sage-like' ? '#d4a843' : p === 'principled' ? '#3b82f6' : p === 'deliberate' ? '#a855f7' : p === 'habitual' ? '#f59e0b' : p === 'reflexive' ? '#ef4444' : '#4b5563';
      return `<div class="stat"><div class="stat-dot" style="background:${color}"></div>${p || 'non-reasoning'} <span class="stat-count">${n}</span></div>`;
    }).join('');

  document.getElementById('sidebarStats').innerHTML = SECTIONS.map(sec => {
    const n = C.filter(c=>c.type===sec.key).length;
    return `<div class="legend-item"><div class="legend-swatch" style="background:${sec.color}"></div>${sec.label}: <strong>${n}</strong></div>`;
  }).join('') + `<div style="margin-top:6px;border-top:1px solid var(--border);padding-top:4px;color:var(--text-dim)">Total: <strong style="color:var(--gold)">${C.length}</strong></div>`;
}

function renderContent() {
  const f = getFiltered();
  let html = '';

  SECTIONS.forEach(sec => {
    const items = f.filter(c => c.type === sec.key);
    if (activeTypeFilter !== 'all' && activeTypeFilter !== sec.key) return;
    if (items.length === 0 && activeTypeFilter === 'all') return;

    html += `<div class="section" id="section-${sec.key}">
      <div class="section-header" onclick="toggleSection('${sec.key}')">
        <div class="section-icon" style="background:${sec.color}">${sec.icon}</div>
        <span class="section-title">${sec.label}</span>
        <span class="section-subtitle">${sec.sub}</span>
        <span class="section-count">${items.length}</span>
        <span class="section-toggle">▼</span>
      </div><div class="cards-grid">`;

    items.forEach(c => {
      const exp = expandedCard === c.id;
      const stBadges = (c.subtype||[]).map(st => `<span class="badge badge-subtype" data-st="${st}">${st}</span>`).join('');
      const proxBadge = c.proximity ? `<span class="badge badge-prox-${c.proximity}">${c.proximity.charAt(0).toUpperCase() + c.proximity.slice(1).replace(/-/g, ' ')}</span>` : '';
      const rulesHtml = (c.rules||[]).filter(r=>r!=='ALL').map(r => `<span class="badge badge-rule">${r}</span>`).join('');
      const depsHtml = (c.deps||[]).map(d => `<span class="dep-tag ${EXTERNALS.includes(d)?'external':''}">${d}</span>`).join('');
      const conHtml = (c.connects||[]).map(id => {
        const t = C.find(x=>x.id===id);
        return `<span class="dep-tag">${t ? t.name : id}</span>`;
      }).join('');

      html += `<div class="card ${exp?'expanded':''}" data-type="${c.type}" data-id="${c.id}" onclick="toggleCard('${c.id}')">
        <div class="card-top">
          <span class="card-name">${c.name}</span>
          <div class="card-badges">
            ${stBadges}
            <span class="badge badge-status-${c.status}">${c.status}</span>
            ${proxBadge}
            <span class="badge badge-ext">${c.ext}</span>
          </div>
        </div>
        <div class="card-desc">${c.desc}</div>
        <div class="card-path">${c.path}</div>
        <div class="card-details">
          <div class="detail-row"><span class="detail-label">Priority</span><span class="detail-value"><span class="priority-tag">${c.priority}</span></span></div>
          ${c.rules.length ? `<div class="detail-row"><span class="detail-label">Rules</span><span class="detail-value">${rulesHtml}</span></div>` : ''}
          ${c.deps.length ? `<div class="detail-row"><span class="detail-label">Depends on</span><span class="detail-value">${depsHtml}</span></div>` : ''}
          ${c.connects.length ? `<div class="detail-row"><span class="detail-label">Connects to</span><span class="detail-value">${conHtml}</span></div>` : ''}
        </div>
      </div>`;
    });
    html += '</div></div>';
  });

  document.getElementById('content').innerHTML = html;
}

function toggleSection(key) { document.getElementById('section-'+key)?.classList.toggle('collapsed'); }
function toggleCard(id) { expandedCard = expandedCard===id ? null : id; renderContent(); }

document.querySelectorAll('[data-filter-type]').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('[data-filter-type]').forEach(b=>b.classList.remove('active'));
    btn.classList.add('active');
    activeTypeFilter = btn.dataset.filterType;
    renderStats(); renderContent();
  });
});
document.querySelectorAll('[data-filter-status]').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('[data-filter-status]').forEach(b=>b.classList.remove('active'));
    btn.classList.add('active');
    activeStatusFilter = btn.dataset.filterStatus;
    renderStats(); renderContent();
  });
});
document.querySelectorAll('[data-filter-prox]').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('[data-filter-prox]').forEach(b=>b.classList.remove('active'));
    btn.classList.add('active');
    activeProxFilter = btn.dataset.filterProx;
    renderStats(); renderContent();
  });
});
document.getElementById('searchBox').addEventListener('input', e => {
  searchTerm = e.target.value; renderStats(); renderContent();
});

renderStats(); renderContent();
</script>
</body>
</html>
