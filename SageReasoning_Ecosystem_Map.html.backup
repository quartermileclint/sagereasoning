  {id:"reasoning-4stage",name:"4-Stage Evaluation Sequence",type:"reasoning",subtype:["multi-step","logical"],status:"scaffolded",ext:".json",path:"/stoic-brain/scoring.json",desc:"Prohairesis filter (logical: in my control?) > Kathekon (heuristic: appropriate?) > Passion diagnosis (causal: what false judgement?) > Unified virtue (reflective: whole character?). The master reasoning chain.",deps:["engine-stoic-brain-v3"],rules:["R4","R6b","R6c"],priority:"P6",proximity:"sage-like",connects:["tool-sage-reason","tool-sage-score","agent-mentor"]},
  {id:"reasoning-prohairesis",name:"Prohairesis Filter",type:"reasoning",subtype:["logical"],status:"verified",ext:".json",path:"/stoic-brain/psychology.json",desc:"Stage 1: Binary control check. Is this within the agent's sphere of choice? Logical deduction from dichotomy of control.",deps:["engine-stoic-brain-v3"],rules:["R6"],priority:"P6",proximity:"sage-like",connects:["reasoning-4stage"]},
  {id:"reasoning-kathekon",name:"Kathekon Assessment",type:"reasoning",subtype:["heuristic"],status:"verified",ext:".json",path:"/stoic-brain/action.json",desc:"Stage 2: Appropriate action evaluation. Role-based duties, social obligations, situational propriety. Rule-of-thumb reasoning from oikeiosis.",deps:["engine-stoic-brain-v3"],rules:["R6"],priority:"P6",proximity:"sage-like",connects:["reasoning-4stage","reasoning-oikeiosis"]},
